    <!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration Page</title>
    <link rel="stylesheet" href="./css/registration_style.css">
    <link rel="icon" type="image/x-icon" href="./img/logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        /* Add styles specific to registration page here */
        #top_frame {
            background-color: purple;
            color: white;
            padding: 20px;
            text-align: center;
        }

        #bottom_frame {
            background-color: lightblue;
            padding: 20px;
        }

        #menu_title {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 20px;
        }

        #menu_list {
            list-style: none;
            padding: 0;
        }

        #menu_list li {
            margin-bottom: 10px;
        }

        #registration_form {
            width: 80%;
            max-width: 400px;
            margin: auto;
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 5px;
            background-color: #f9f9f9;
        }

        #registration_form input {
            margin-bottom: 15px;
        }
    </style>
</head>

<body>
    <div id="top_frame">
        <div id="logo_slogan">
            <img id="logo" src="./img/logo.png" alt="Logo">
            <img id="slogan" src="./img/slogan.png" alt="Slogan">
        </div>
        <h1>Registration Page</h1>
    </div>

    <div id="bottom_frame">
        <div id="menu_title">Menu</div>
        <ul id="menu_list">
            <li><a href="/">Welcome Page</a></li>
            <li><a href="about.html">About Page</a></li>
            <li><a href="terms.html">Terms Page</a></li>
        </ul>
    </div>

    <div id="registration_form">
        <h2>Register</h2>
        <form id="reg_form">
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" placeholder="user@server.com" required>
            <label for="ver_email">Verify Email:</label>
            <input type="email" id="ver_email" name="ver_email" placeholder="Re-enter your email" required>
            <label for="password">Password:</label>
            <input type="password" id="password" name="password" placeholder="Password" required>
            <label for="ver_password">Verify Password:</label>
            <input type="password" id="ver_password" name="ver_password" placeholder="Re-enter your password" required>
            <button type="button" id="reg_button">Register</button>
        </form>
    </div>

    <script>
        document.getElementById('reg_button').addEventListener('click', function() {
            const email = document.getElementById('email').value;
            const verEmail = document.getElementById('ver_email').value;
            const password = document.getElementById('password').value;
            const verPassword = document.getElementById('ver_password').value;

            if (email !== verEmail) {
                alert('Emails do not match!');
                return;
            }

            if (password !== verPassword) {
                alert('Passwords do not match!');
                return;
            }

            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                alert('Invalid email format!');
                return;
            }

            if (!/^[a-zA-Z0-9]+$/.test(password)) {
                alert('Password can only contain letters and numbers!');
                return;
            }

            // Simulate sending data to the server
            console.log('Registration successful!');
            // Redirect to terms page
            window.location.href = 'terms.html';
        });
    </script>
</body>

</html>
