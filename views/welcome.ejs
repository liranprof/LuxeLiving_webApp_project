<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">


    <link rel="stylesheet" href="./css/welcome_style.css">
    <link rel="icon" type="image/x-icon" href="./img/logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <title>welcome page Homeware Haven </title>
</head>
<style>

</style>

<body id="body">
    <div id="div_header">

        <div id="div_header_img">
            <img id="img_header" src="./img/header_welcome.png" alt="">
        </div>

        <div id="div_header_items">

            <div id="div_logo_slogan">
                <img id="img_logo" src="./img/logo.png" alt=""></img>
                <img id="img_slogan" src="./img/slogan.png" alt=""></img>
            </div>

            <div id="div_email_password">
                <i id="i_Enter_Email">Enter Email:</i>
                <input id="input_Email" type="email" placeholder="user@server.com">
                <i id="i_Enter_password">Enter password:</i>
                <input id="input_password" type="password" placeholder="password">
                <button id="button_login">Login</button>
            </div>


            <div id="div_reg_search">
                <a id="hyper_reg" href="regstration">registration</a>

                <div id="div_search_filter">

                    <div id="div_drop_down_filter">
                        <button id="btn_filter" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <img id="img_filter" src="./img/fillter_icon.png" alt="">
                        </button>
                        <ul id="filter_menu" class="dropdown-menu">
                            <li><a class="dropdown-item" href="#" data-filter="All">All</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Appliance">Appliance</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Baking">Baking</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Cooking">Cooking</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Cookware">Cookware</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Cutlery">Cutlery</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Dinnerware">Dinnerware</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Storage">Storage</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Utensils">Utensils</a></li>
                        </ul>
                    </div>

                    <div id="div_input_search_btn">
                        <input id="input_search" type="search" placeholder="Search" aria-label="Search">
                        <button id="btn_search" type="submit">Search</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="div_menu">
        <a id="a_menu_title">Menu</a>
        <div id="div_sidebar_menu">
            <a class="a_menu">Products list</a>
            <% if (typeof Products_Types==='undefined' || Products_Types.length===0) { %>
                <p>No Products_Types available.</p>
                <% } else { %>
                    <%for(let i=0; i < Products_Types.length; i++) { %>
            <a class="a_menu" href="#" data-filter="<%=Products_Types[i]%>"><%= Products_Types[i] %></a>
            <% } %>
            <% } %>
            <a class="a_menu" id="About" data-filter="About">About</a>
            <a class="a_menu" id="Terms" data-filter="Terms">Terms</a>
        </div>
    </div>


    <div id="div_item_list">
        <a id="a_item_list_title">Products list</a>
        <div id="div_sidebar_item_list">
            <div id="cards_div" class="row row-cols-1 row-cols-md-2 g-4">
                <% if (typeof Products==='undefined' || Products.length===0) { %>
                    <p>No products available.</p>
                    <% } else { %>
                        <%for(let i=0; i < Products.length; i++) { %>
                            <div id="card" class="card_div_<%= Products[i].Product_id %>">
                                
                                <img id="img_card" src="./prod_img/<%= Products[i].Name %>.jpeg">
                                <hr>
                                <i id="i_item_name">
                                    <%= Products[i].Name %>
                                </i><br>
                                <i id="i_item_info1">
                                    <%= Products[i].Type %>
                                </i><br>
                                <i id="i_item_info2">
                                    <%= Products[i]. Price%>$
                                </i><br>
                                <i id="i_item_info3">
                                    <%= Products[i].discount %>
                                </i><br>
                                <i id="i_item_info4">
                                    <%= Products[i].Rank %>
                                </i><br>

                            </div>
                            <% } %>
                                <% } %>
            </div>
        </div>
    </div>
    <script src="./scripts/index.js"></script>
    <script src="../app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
</body>

</html>